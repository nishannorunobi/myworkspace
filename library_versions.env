# Package manager to use: apt | yum | dnf | apk
PKG_MANAGER="apt"

# OS-level package versions installed inside the container
# Set to "latest" to always grab the newest, or pin exact version e.g. "1:8.4p1-5"

GIT_VERSION="latest"
BUILD_ESSENTIAL_VERSION="latest"

# -----------------------------------------------
# Project-specific tools — uncomment and set as needed
# -----------------------------------------------

# PYTHON_VERSION="3.10"
# NODE_VERSION="20"
# FFMPEG_VERSION="latest"
